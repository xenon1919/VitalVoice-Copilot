APP_NAME=Personal Health Voice Copilot
ENV=dev
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

GEMINI_API_KEY=
GEMINI_MODEL= gemini-3.1-pro-preview
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=4
MEMORY_TOP_K=3

DOCS_DIR=data/docs
RAG_INDEX_DIR=storage/faiss
MEMORY_INDEX_DIR=storage/memory_faiss
MEMORY_DB_PATH=data/memory/memory_records.json

WHISPER_MODEL_SIZE=base
TTS_ENGINE=gtts
OUTPUT_AUDIO_PATH=storage/response.mp3
